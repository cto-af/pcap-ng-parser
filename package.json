  },
  "devDependencies": {
    "@cto.af/eslint-config": "^6.2.5",
    "@eslint/markdown": "^7.5.1",
    "@types/node": "^25.5.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-mocha": "^11.2.0",
    "ether-frame": "^0.2.0",
    "playwright": "^1.58.2",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.4",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
