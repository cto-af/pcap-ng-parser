      "name": "Joe Hildebrand <joe-github@cursive.net>"
    }
  ],
  "license": "BSD-3",
  "dependencies": {
    "@cto.af/utils": "1.4.2",
    "@leichtgewicht/ip-codec": "~2.0.5",
